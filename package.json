{
  "name": "mcp-yandex-metrica",
  "version": "1.0.0",
  "description": "MCP server for the Yandex Metrica API — list counters and goals, pull web-analytics statistics (visits, users, bounce rate, conversions) from AI agents.",
  "mcpName": "io.github.askads/mcp-yandex-metrica",
  "type": "module",
  "bin": {
    "mcp-yandex-metrica": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.check.json",
    "smoke": "node --import tsx src/smoke.ts",
    "test": "node --import tsx --test $(find src -name '*.test.ts')",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "yandex",
    "yandex-metrica",
    "yandex-metrika",
    "analytics",
    "web-analytics"
  ],
  "license": "MIT",
  "author": "Aleksandr Kovalko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/askads/mcp-yandex-metrica.git"
  },
  "homepage": "https://github.com/askads/mcp-yandex-metrica#readme",
  "bugs": {
    "url": "https://github.com/askads/mcp-yandex-metrica/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  }
}
